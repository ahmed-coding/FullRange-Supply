# Vite Environment Variables
# Copy this file to .env.local and fill in the actual values for local development

# API Configuration
VITE_API_URL=https://api.amzglobalsourcing.com

# Google Analytics
VITE_GA_ID=UA-XXXXXXXXX-X

# Environment
VITE_ENV=development

# Sentry Error Tracking (Optional)
VITE_SENTRY_DSN=

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_TRACKING=true
VITE_ENABLE_FORM_SUBMISSION=true

# API Keys (for external services)
VITE_RECAPTCHA_KEY=

# Deployment
VITE_DEPLOYMENT_URL=http://localhost:5173
VITE_DEPLOYMENT_ENV=local
